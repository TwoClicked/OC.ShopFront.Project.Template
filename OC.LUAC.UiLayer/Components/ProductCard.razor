@using OC.LUAC.UiLayer.DTO.Products
@inject IConfiguration Config

<div class="bg-neutral-900 rounded-xl shadow-md overflow-hidden hover:scale-105 transition-transform flex flex-col">
    <!-- Image Carousel -->
    <div class="relative w-full h-64 overflow-hidden">
        <img src="@CurrentImageUrl"
             alt="@Product.Name_En"
             class="absolute inset-0 w-full h-full object-cover transition duration-300" />

        @if (HasMultipleImages)
        {
            <!-- Left Arrow -->
            <button @onclick="ShowPrevImage"
                    class="absolute left-2 top-1/2 -translate-y-1/2 bg-black/50 text-white p-2 rounded-full hover:bg-black/70">
                ‹
            </button>

            <!-- Right Arrow -->
            <button @onclick="ShowNextImage"
                    class="absolute right-2 top-1/2 -translate-y-1/2 bg-black/50 text-white p-2 rounded-full hover:bg-black/70">
                ›
            </button>

            <!-- Dots -->
            <div class="absolute bottom-2 w-full flex justify-center space-x-2">
                @for (int i = 0; i < Product.Images.Count; i++)
                {
                    <span class="w-3 h-3 rounded-full cursor-pointer transition"
                          style="background-color:@(i == currentIndex ? "#f59e0b" : "#d1d5db")"
                          @onclick="() => SetImage(i)">
                    </span>
                }
            </div>
        }
    </div>

    <!-- Product Info -->
    <div class="p-4 flex flex-col flex-grow">
        <h3 class="text-lg font-semibold text-bg-white">@Product.Name_En</h3>
        <p class="text-bg-white">@Product.Price.ToString("C")</p>

        <div class="mt-auto">
            <a href="/product/@Product.Id"
               class="mt-3 inline-block text-sm font-medium text-amber-600 hover:text-amber-800 hover:underline">
                View Details
            </a>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ProductDto Product { get; set; } = default!;

    private int currentIndex = 0;

    private bool HasMultipleImages =>
        Product.Images != null && Product.Images.Count > 1;

    private string CurrentImageUrl
    {
        get
        {
            if (Product.Images != null && Product.Images.Count > 0)
                return Config["ApiBaseUrl"]!.TrimEnd('/') + Product.Images[currentIndex].ImageUrl;

            if (!string.IsNullOrWhiteSpace(Product.ThumbnailUrl))
                return Config["ApiBaseUrl"]!.TrimEnd('/') + Product.ThumbnailUrl;

            return "https://placehold.co/600x800";
        }
    }

    private void ShowNextImage()
    {
        if (Product.Images == null || Product.Images.Count == 0) return;
        currentIndex = (currentIndex + 1) % Product.Images.Count;
    }

    private void ShowPrevImage()
    {
        if (Product.Images == null || Product.Images.Count == 0) return;
        currentIndex = (currentIndex - 1 + Product.Images.Count) % Product.Images.Count;
    }

    private void SetImage(int index)
    {
        if (Product.Images == null || Product.Images.Count == 0) return;
        currentIndex = index;
    }
}
