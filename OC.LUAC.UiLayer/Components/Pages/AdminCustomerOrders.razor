@page "/admin/customers/{customerId:int}/orders"
@using OC.LUAC.UiLayer.DTO.AdminDash
@using OC.LUAC.UiLayer.DTO.Order
@inject HttpClient Http
@inject AdminAuthService AdminAuth
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject Microsoft.Extensions.Localization.IStringLocalizer<OC.LUAC.UiLayer.Components.Pages.AdminCustomerOrders> L

<h2 class="text-2xl font-bold mb-6 text-amber-600">
    @L["OrdersFor"]
    @if (customer != null)
    {
        <span>@customer.FirstName @customer.LastName (@customer.Email)</span>
        @if (customer.IsGuest)
        {
            <span class="text-2xl font-bold mb-6 text-yellow-200"> - @L["GuestAccount"]</span>
        }
        else
        {
            <span class="text-2xl font-bold mb-6 text-yellow-200"> - @L["RegisteredAccount"]</span>
        }
    }
</h2>
<!-- Filters -->
<div class="flex justify-between items-center mb-4 space-x-4">
    <input type="text"
           @bind="searchTerm"
           @bind:event="oninput"
           placeholder="@L["OrderNumber"]"
           class="px-4 py-2 rounded-md bg-neutral-800 border border-neutral-600 text-amber-400 placeholder-gray-500 w-1/3" />
    <div class="flex space-x-4 text-sm text-gray-300">
        @foreach (var status in allStatuses)
        {
            <label class="flex items-center space-x-1">
                <input type="checkbox" checked="@selectedStatuses.Contains(status)"
                       @onchange="e => ToggleStatus(status, e.Value as bool?)"
                       class="form-checkbox bg-neutral-700 border-neutral-500 text-amber-500" />
                <span>@L[status]</span>
            </label>
        }
    </div>
    <select class="px-3 py-2 rounded-md bg-neutral-800 border border-neutral-600 text-amber-400"
            @onchange="OnPageSizeChanged">
        <option value="8">8 @L["PerPage"]</option>
        <option value="16">16 @L["PerPage"]</option>
        <option value="24">24 @L["PerPage"]</option>
    </select>
</div>
@if (pagedOrders == null)
{
    <p class="text-gray-400">@L["LoadingOrders"]</p>
}
else if (pagedOrders.Count == 0)
{
    <p class="text-gray-400">@L["NoMatchingOrders"]</p>
}
else
{
    <div class="space-y-6">
        @foreach (var order in pagedOrders)
        {
            <div class="bg-neutral-800 rounded-lg p-6 shadow space-y-4">
                <!-- Header -->
                <div class="flex justify-between items-center">
                    <h3 class="text-lg font-semibold text-amber-600">@L["Order"] @order.OrderNumber</h3>
                    <span class="px-3 py-1 rounded text-sm font-semibold
                                         @(order.Status == "Shipped" ? "bg-green-700 text-green-200" :
                                                             order.Status == "Cancelled" ? "bg-red-700 text-red-200" :
                                                             order.Status == "Processing" ? "bg-blue-700 text-blue-200" :
                                                             "bg-yellow-700 text-yellow-200")">
                @L[order.Status]
            </span>
        </div>
        <p class="text-sm text-gray-400">@L["Placed"]: @order.CreatedAt.ToLocalTime().ToString("g")</p>
        <!-- Shipping Info -->
        <div class="bg-neutral-900 rounded p-4 text-sm space-y-1">
            <p><span class="text-amber-600">@L["ShippingInfo"]:</span></p>
            <p><span class="text-gray-400">@L["Address"]:</span> @order.ShippingAddress</p>
            <p><span class="text-gray-400">@L["City"]:</span> @order.ShippingCity</p>
            <p><span class="text-gray-400">@L["PostalCode"]:</span> @order.ShippingPostalCode</p>
            <p><span class="text-gray-400">@L["Country"]:</span> @order.ShippingCountry</p>
        </div>
        <!-- Tracking Info -->
        @if (!string.IsNullOrEmpty(order.TrackingNumber))
                {
                    <div class="bg-neutral-900 rounded p-4 text-sm space-y-1">
                        <p><span class="text-gray-400">@L["TrackingNumber"]:</span> @order.TrackingNumber</p>
                        @if (!string.IsNullOrEmpty(order.TrackingUrl))
                        {
                            <p>
                                <a href="@order.TrackingUrl" target="_blank"
                                   class="text-amber-600 hover:underline">
                                    @L["TrackPackage"]
                                </a>
                            </p>
                        }
                    </div>
                }
                <!-- Items -->
                <table class="w-full text-sm text-amber-600 border-t border-neutral-700 mb-4">
                    <thead class="text-left text-gray-400 uppercase text-xs">
                        <tr>
                            <th class="py-2">@L["Product"]</th>
                            <th class="py-2">@L["Size"]</th>
                            <th class="py-2">@L["Quantity"]</th>
                            <th class="py-2">@L["UnitPrice"]</th>
                            <th class="py-2">@L["LineTotal"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in order.Items)
                        {
                            <tr class="border-t border-neutral-700">
                                <td class="py-2">@item.ProductName</td>
                                <td class="py-2">@item.Size</td>
                                <td class="py-2">@item.Quantity</td>
                                <td class="py-2">@item.UnitPrice.ToString("C", new System.Globalization.CultureInfo("de-DE"))</td>
                                <td class="py-2">@((item.Quantity * item.UnitPrice).ToString("C", new System.Globalization.CultureInfo("de-DE")))</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <!-- Totals -->
                <div class="bg-neutral-900 rounded p-4 space-y-2 text-sm">
                    <p class="flex justify-between">
                        <span class="text-gray-400">@L["Subtotal"]:</span>
                        <span class="text-amber-600">@order.Subtotal.ToString("C", new System.Globalization.CultureInfo("de-DE"))</span>
                    </p>
                    @if (order.Discount > 0)
                    {
                        <p class="flex justify-between text-red-400">
                            <span>@L["Discount"]:</span>
                            <span>-@order.Discount.ToString("C", new System.Globalization.CultureInfo("de-DE"))</span>
                        </p>
                    }
                    <p class="flex justify-between">
                        <span class="text-gray-400">@L["Shipping"]:</span>
                        <span class="text-amber-600">@order.ShippingCost</span>
                    </p>
                    <hr class="border-neutral-700" />
                    <p class="flex justify-between font-semibold">
                        <span>@L["Total"]:</span>
                        <span class="text-amber-500">@order.TotalAfterDiscount.ToString("C", new System.Globalization.CultureInfo("de-DE"))</span>
                    </p>
                </div>
                <!-- Admin Actions -->
                @if (order.Status == "PendingPayment")
                {
                    <div class="flex space-x-4 mt-4">
                        <button class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded text-sm"
                                @onclick="() => ConfirmAndMarkPaid(order.Id)">
                            @L["MarkPaid"]
                        </button>
                        <button class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded text-sm"
                                @onclick="() => ConfirmAndCancel(order.Id, order.Status)">
                            @L["Cancel"]
                        </button>
                    </div>
                }
                else if (order.Status == "Processing")
                {
                    <div class="space-y-2 mt-4 ">
                        <input type="text" placeholder="@L["TrackingNumber"]"
                               @bind="order.TrackingNumber"
                               class="w-1/3 px-3 py-2 rounded bg-neutral-800 border border-neutral-600 text-amber-400" />
                        <input type="text" placeholder="@L["TrackingUrl"]"
                               @bind="order.TrackingUrl"
                               class="w-1/2 px-3 py-2 rounded bg-neutral-800 border border-neutral-600 text-amber-400" />
                        <button class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded text-sm"
                                @onclick="() => ConfirmAndMarkShipped(order.Id, order.TrackingNumber, order.TrackingUrl)">
                            @L["MarkShipped"]
                        </button>
                        <button class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded text-sm"
                                @onclick="() => ConfirmAndCancel(order.Id, order.Status)">
                            @L["Cancel"]
                        </button>
                    </div>
                }
            </div>
        }
    </div>
    <!-- Pagination -->
    <div class="flex flex-col items-center space-y-2 mt-6 text-sm text-gray-400">
        <div class="flex items-center space-x-4">
            <button @onclick="PrevPage" disabled="@(!CanPrevPage)"
                    class="w-24 px-3 py-1 rounded bg-neutral-800 hover:bg-neutral-700 disabled:opacity-50">
                @L["Previous"]
            </button>
            <span class="text-amber-400">@L["PageOf", currentPage, totalPages]</span>
            <button @onclick="NextPage" disabled="@(!CanNextPage)"
                    class="w-24 px-3 py-1 rounded bg-neutral-800 hover:bg-neutral-700 disabled:opacity-50">
                @L["Next"]
            </button>
        </div>
    </div>
}
<button class="mt-6 bg-neutral-700 hover:bg-neutral-600 text-white px-4 py-2 rounded"
        @onclick="@(() => Nav.NavigateTo("/admin?tab=Customers", true))">
    @L["BackToCustomers"]
</button>

@code {
    [Parameter] public int CustomerId { get; set; }
    private List<AdminOrderSummaryDto> allOrders = new();
    private List<AdminOrderSummaryDto> pagedOrders = new();
    private CustomerProfileDto? customer;

    private string _searchTerm = "";
    private string searchTerm
    {
        get => _searchTerm;
        set
        {
            _searchTerm = value ?? "";
            currentPage = 1;
            ApplyFilters();
        }
    }

    private readonly string[] allStatuses = { "PendingPayment", "Processing", "Shipped", "Cancelled" };
    private HashSet<string> selectedStatuses = new() { "PendingPayment", "Processing", "Shipped", "Cancelled" };

    private int currentPage = 1;
    private int pageSize = 8;
    private int totalPages = 1;
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            await LoadCustomer();
            await LoadOrders();
            _initialized = true;
            StateHasChanged();
        }
    }

    private async Task LoadCustomer()
    {
        var token = await AdminAuth.GetTokenAsync();
        if (string.IsNullOrEmpty(token)) return;

        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        try
        {
            customer = await Http.GetFromJsonAsync<CustomerProfileDto>($"customers/{CustomerId}");
        }
        catch (Exception ex)
        {
            Console.WriteLine("⚠️ Failed to load customer details: " + ex.Message);
        }
    }

    private async Task LoadOrders()
    {
        var token = await AdminAuth.GetTokenAsync();
        if (string.IsNullOrEmpty(token)) return;

        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        try
        {
            allOrders = await Http.GetFromJsonAsync<List<AdminOrderSummaryDto>>(
                $"customers/{CustomerId}/orders"
            ) ?? new();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine("⚠️ Failed to load customer orders: " + ex.Message);
            allOrders = new();
        }
    }

    private void ApplyFilters()
    {
        var filtered = string.IsNullOrWhiteSpace(searchTerm) || searchTerm == "ORD-"
            ? allOrders
            : allOrders.Where(o => o.OrderNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();

        filtered = filtered.Where(o => selectedStatuses.Contains(o.Status)).ToList();

        filtered = filtered
            .OrderBy(o => o.Status == "PendingPayment" ? 0 :
                          o.Status == "Processing" ? 1 :
                          o.Status == "Shipped" ? 2 :
                          o.Status == "Cancelled" ? 3 : 4)
            .ThenByDescending(o => o.CreatedAt)
            .ToList();

        totalPages = (int)Math.Ceiling(filtered.Count / (double)pageSize);
        if (currentPage > totalPages) currentPage = totalPages == 0 ? 1 : totalPages;

        pagedOrders = filtered
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void ToggleStatus(string status, bool? isChecked)
    {
        if (isChecked == true)
            selectedStatuses.Add(status);
        else
            selectedStatuses.Remove(status);

        currentPage = 1;
        ApplyFilters();
    }

    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            pageSize = size;
            currentPage = 1;
            ApplyFilters();
        }
    }

    private void PrevPage()
    {
        if (currentPage > 1) currentPage--;
        ApplyFilters();
    }

    private void NextPage()
    {
        if (currentPage < totalPages) currentPage++;
        ApplyFilters();
    }

    private bool CanPrevPage => currentPage > 1;
    private bool CanNextPage => currentPage < totalPages;

    // === Admin Actions ===
    private async Task<bool> Confirm(string message)
    {
        return await JS.InvokeAsync<bool>("confirm", message);
    }

    private async Task ConfirmAndMarkPaid(int orderId)
    {
        if (await Confirm("Are you sure you want to mark this order as PAID?"))
        {
            await MarkPaid(orderId);
        }
    }

    private async Task ConfirmAndCancel(int orderId, string status)
    {
        if (await Confirm("Are you sure you want to CANCEL this order?"))
        {
            await CancelOrder(orderId, status);
        }
    }

    private async Task ConfirmAndMarkShipped(int orderId, string trackingNumber, string trackingUrl)
    {
        if (string.IsNullOrWhiteSpace(trackingNumber) || string.IsNullOrWhiteSpace(trackingUrl))
        {
            await JS.InvokeVoidAsync("alert", "Please fill in both Tracking Number and Tracking URL before shipping.");
            return;
        }

        if (await Confirm("Are you sure you want to mark this order as SHIPPED?"))
        {
            await MarkShipped(orderId, trackingNumber, trackingUrl);
        }
    }

    private async Task MarkPaid(int orderId)
    {
        await Http.PutAsync($"orders/{orderId}/mark-paid", null);
        await LoadOrders();
    }

    private async Task CancelOrder(int orderId, string status)
    {
        string url = status == "Processing"
            ? $"orders/{orderId}/cancel-processing"
            : $"orders/{orderId}/cancel-nopayment";

        await Http.PutAsync(url, null);
        await LoadOrders();
    }

    private async Task MarkShipped(int orderId, string trackingNumber, string trackingUrl)
    {
        var payload = new { TrackingNumber = trackingNumber, TrackingUrl = trackingUrl };
        await Http.PutAsJsonAsync($"orders/{orderId}/ship", payload);
        await LoadOrders();
    }
}
