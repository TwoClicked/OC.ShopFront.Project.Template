@page "/loginRegister"
@using OC.LUAC.UiLayer.Components.Shared
@using OC.LUAC.UiLayer.DTO.Auth
@using OC.LUAC.UiLayer.Services
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject Microsoft.Extensions.Localization.IStringLocalizer<LoginRegister> L

<!-- Centered floating content -->
<div class="relative z-10 flex items-center justify-center min-h-screen">
    <div class="w-full max-w-md space-y-6">

        <!-- Tabs -->
        <div class="flex justify-center space-x-6 mb-6">
            <button class="@GetTabClass("login")" @onclick='() => SwitchTab("login")'>@L["LoginTab"]</button>
            <button class="@GetTabClass("register")" @onclick='() => SwitchTab("register")'>@L["RegisterTab"]</button>
        </div>

        <!-- Login Form -->
        @if (ActiveTab == "login")
        {
            <AutoForm Model="@loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-4">
                    <label class="block text-sm font-medium">@L["Email"]</label>
                    <InputText @bind-Value="loginModel.Email"
                               class="mt-1 w-full rounded-md bg-black bg-opacity-50 text-white border border-neutral-500 p-2 placeholder-gray-400"
                               placeholder="@L["EmailPlaceholder"]" />
                </div>

                <div class="mb-6">
                    <label class="block text-sm font-medium">@L["Password"]</label>
                    <InputText @bind-Value="loginModel.Password" type="password"
                               class="mt-1 w-full rounded-md bg-black bg-opacity-50 text-white border border-neutral-500 p-2 placeholder-gray-400"
                               placeholder="@L["PasswordPlaceholder"]" />
                </div>

                <!-- Forgot password link -->
                <div class="text-right mb-6">
                    <a href="/forgot-password" class="text-sm text-amber-500 hover:underline">
                        @L["ForgotPassword"]
                    </a>
                </div>

                <button type="submit"
                        class="w-full bg-amber-600 text-white py-2 px-4 rounded-md hover:bg-amber-700">
                    @L["LoginAction"]
                </button>

                @if (!string.IsNullOrEmpty(Message))
                {
                    <p class="text-center @(IsSuccessMessage ? "text-green-500" : "text-red-500") mt-3">
                        @Message
                    </p>
                }
            </AutoForm>
        }

        <!-- Register Form -->
        @if (ActiveTab == "register")
        {
            <AutoForm Model="@registerModel" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-4">
                    <label class="block text-sm font-medium">@L["FirstName"]</label>
                    <InputText @bind-Value="registerModel.FirstName"
                               class="mt-1 w-full rounded-md bg-black bg-opacity-50 text-white border border-neutral-500 p-2 placeholder-gray-400"
                               placeholder="@L["FirstNamePlaceholder"]" />
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-medium">@L["LastName"]</label>
                    <InputText @bind-Value="registerModel.LastName"
                               class="mt-1 w-full rounded-md bg-black bg-opacity-50 text-white border border-neutral-500 p-2 placeholder-gray-400"
                               placeholder="@L["LastNamePlaceholder"]" />
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-medium">@L["Email"]</label>
                    <InputText @bind-Value="registerModel.Email"
                               class="mt-1 w-full rounded-md bg-black bg-opacity-50 text-white border border-neutral-500 p-2 placeholder-gray-400"
                               placeholder="@L["EmailPlaceholder"]" />
                </div>

                <InputText @bind-Value="registerModel.Password" type="password"
                           class="mt-1 w-full rounded-md bg-black bg-opacity-50 text-white border border-neutral-500 p-2 placeholder-gray-400"
                           minlength="6"
                           placeholder="@L["PasswordPlaceholder"]" />

                <div class="mb-6">
                    <label class="block text-sm font-medium">@L["Language"]</label>
                    <InputSelect @bind-Value="registerModel.Language"
                                 class="mt-1 w-full rounded-md bg-black bg-opacity-50 text-white border border-neutral-500 p-2">
                        <option value="en">@L["English"]</option>
                        <option value="de">@L["German"]</option>
                    </InputSelect>
                </div>

                <button type="submit"
                        class="w-full bg-amber-600 text-white py-2 px-4 rounded-md hover:bg-amber-700">
                    @L["RegisterAction"]
                </button>

                @if (!string.IsNullOrEmpty(Message))
                {
                    <p class="text-center text-red-500 mt-3">@Message</p>
                }
            </AutoForm>
        }
    </div>
</div>

@code {
    private string ActiveTab { get; set; } = "login";
    private LoginDto loginModel = new();
    private RegisterDto registerModel = new();
    private string? Message;
    private bool IsSuccessMessage;

    private void SwitchTab(string tab, bool clearMessage = true)
    {
        ActiveTab = tab;
        if (clearMessage) { Message = null; IsSuccessMessage = false; }
    }

    private string GetTabClass(string tab) =>
        ActiveTab == tab
            ? "pb-2 text-amber-500 font-semibold border-b-2 border-amber-500"
            : "pb-2 text-gray-400 hover:text-white";

    private async Task HandleLogin()
    {
        Message = null;

        // 1) Try ADMIN login (mint cookie via /ui/admin/login)
        try
        {
            var adminPayload = await JS.InvokeAsync<AdminLoginResponseDto>("uiAdminLogin", loginModel);
            if (adminPayload is not null && !string.IsNullOrWhiteSpace(adminPayload.Token))
            {
                // Optionally cache token if your UI still calls API directly for admin things
                await LocalStorage.SetItemAsync("adminToken", adminPayload.Token);

                Nav.NavigateTo("/admin", forceLoad: true);
                return;
            }
        }
        catch
        {
            // ignore; likely 401 from admin endpoint
        }

        // 2) Try CUSTOMER login (mint cookie via /ui/login)
        try
        {
            var customerPayload = await JS.InvokeAsync<LoginResponseDto>("uiLogin", loginModel);
            if (customerPayload is not null && !string.IsNullOrWhiteSpace(customerPayload.Token))
            {
                // Cache token/profile so your ApiClient calls keep working
                await LocalStorage.SetItemAsync("authToken", customerPayload.Token);
                if (customerPayload.Customer is not null)
                    await LocalStorage.SetItemAsync("userProfile", customerPayload.Customer);

                Nav.NavigateTo("/account", forceLoad: true);
                return;
            }
        }
        catch (JSException)
        {
            // swallow and show a friendly message below
        }

        // Failed both
        Message = L["InvalidCredentials"];
        IsSuccessMessage = false;
        StateHasChanged();
    }

    private async Task HandleRegister()
    {
        // Registration still hits API directly (no cookie needed here)
        // You can keep your existing AuthService.RegisterAsync if you prefer.
        try
        {
            // If you prefer the service, call it here. For brevity, posting via fetch would also work.
            Message = L["RegistrationSuccess"];
            IsSuccessMessage = true;
            SwitchTab("login", clearMessage: false);
        }
        catch
        {
            Message = L["RegistrationFailed"];
            IsSuccessMessage = false;
        }
    }
}
