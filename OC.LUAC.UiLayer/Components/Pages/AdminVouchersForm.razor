@page "/admin/vouchers/new"
@page "/admin/vouchers/edit/{VoucherId:int}"
@using OC.LUAC.ObjectLayer.Orders
@inject HttpClient Http
@inject NavigationManager Nav
@inject AdminAuthService AdminAuth
@attribute [Authorize(Roles = "Admin")]
@inject Microsoft.Extensions.Localization.IStringLocalizer<AdminVouchersForm> L
@inject IJSRuntime JS

<h2 class="text-2xl font-bold mb-6 text-amber-600">
    @(VoucherId == null ? L["AddVoucher"] : L["EditVoucher"])
</h2>

<AutoForm Model="@vm" OnValidSubmit="@SaveVoucher">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-red-400 mb-4" />

    <div class="space-y-4 bg-neutral-900 p-6 rounded-md border border-neutral-700">
        <!-- Voucher Code -->
        <div>
            <label class="block text-sm font-medium mb-1 text-gray-300">@L["VoucherCodeLabel"] *</label>
            <InputText @bind-Value="vm.Code"
                       class="w-full bg-neutral-800 border border-neutral-600 rounded px-3 py-2 text-amber-600" />
        </div>

        <!-- Free Shipping -->
        <div class="flex items-center space-x-2">
            <InputCheckbox @bind-Value="vm.AppliesToShipping" class="accent-amber-600" />
            <span class="text-gray-300">@L["FreeShippingLabel"]</span>
        </div>

        <!-- Discount Type -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm mb-1 text-gray-300">@L["PercentageDiscountLabel"]</label>
                <InputNumber @bind-Value="vm.Percentage"
                             class="w-full bg-neutral-800 border border-neutral-600 rounded px-3 py-2 text-amber-600" />
            </div>
            <div>
                <label class="block text-sm mb-1 text-gray-300">@L["FlatRateDiscountLabel"]</label>
                <InputNumber @bind-Value="vm.FixedAmount"
                             class="w-full bg-neutral-800 border border-neutral-600 rounded px-3 py-2 text-amber-600" />
            </div>
        </div>

        <!-- Dates (Flatpickr) -->
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm mb-1 text-gray-300">@L["StartDateLabel"]</label>
                <input id="startDate"
                       class="date-input w-full bg-neutral-800 border border-neutral-600 rounded px-3 py-2 text-amber-600"
                       @bind="vm.StartDate"
                       @bind:format="yyyy-MM-dd" />
            </div>
            <div>
                <label class="block text-sm mb-1 text-gray-300">@L["EndDateLabel"]</label>
                <input id="endDate"
                       class="date-input w-full bg-neutral-800 border border-neutral-600 rounded px-3 py-2 text-amber-600"
                       @bind="vm.EndDate"
                       @bind:format="yyyy-MM-dd" />
            </div>
        </div>

        <!-- Max Usage -->
        <div>
            <label class="block text-sm mb-1 text-gray-300">@L["MaxUsageCountLabel"]</label>
            <InputNumber @bind-Value="vm.MaxUsageCount"
                         class="w-full bg-neutral-800 border border-neutral-600 rounded px-3 py-2 text-amber-600" />
        </div>

        <!-- Current Usage (read-only) -->
        @if (VoucherId != null)
        {
            <div>
                <label class="block text-sm mb-1 text-gray-300">@L["CurrentUsageLabel"]</label>
                <input value="@vm.CurrentUsageCount"
                       readonly
                       class="w-full bg-neutral-800 border border-neutral-600 rounded px-3 py-2 text-gray-400 cursor-not-allowed" />
            </div>
        }
    </div>

    <!-- Buttons -->
    <div class="flex justify-end space-x-3 mt-6">
        <button type="button"
                class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded"
                @onclick="Cancel">
            @L["Cancel"]
        </button>
        <button type="submit"
                class="bg-amber-600 hover:bg-amber-700 text-white px-6 py-2 rounded">
            @L["Save"]
        </button>
    </div>

    @if (!string.IsNullOrEmpty(error))
    {
        <p class="text-red-400 mt-4">@error</p>
    }
</AutoForm>

@code {
    [Parameter] public int? VoucherId { get; set; }
    private Voucher vm = new();
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        var token = await AdminAuth.GetTokenAsync();
        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        if (VoucherId != null)
        {
            try
            {
                vm = await Http.GetFromJsonAsync<Voucher>($"vouchers/id/{VoucherId}") ?? new();
            }
            catch
            {
                error = L["LoadError"];
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // ✅ always re-init after render
        await JS.InvokeVoidAsync("initFlatpickr");
    }

    private async Task SaveVoucher()
    {
        try
        {
            HttpResponseMessage resp;
            if (VoucherId == null)
                resp = await Http.PostAsJsonAsync("vouchers", vm);
            else
                resp = await Http.PutAsJsonAsync($"vouchers/{VoucherId}", vm);

            if (resp.IsSuccessStatusCode)
                Nav.NavigateTo("/admin?tab=Vouchers");
            else
                error = await resp.Content.ReadAsStringAsync();
        }
        catch (Exception ex)
        {
            error = L["SaveError"] + ": " + ex.Message;
        }
    }

    private void Cancel()
    {
        Nav.NavigateTo("/admin?tab=Vouchers");
    }
}
