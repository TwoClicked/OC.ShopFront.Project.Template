@page "/admin/shipping-zones/create"
@page "/admin/shipping-zones/edit/{ZoneId:int}"

@inject HttpClient Http
@inject NavigationManager Nav
@inject AdminAuthService AdminAuth

<h2 class="text-2xl font-bold mb-6 text-amber-600">
    @(ZoneId == null ? "Add Shipping Zone" : "Edit Shipping Zone")
</h2>

<AutoForm Model="@vm" OnValidSubmit="@SaveZone">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-red-400 mb-4" />

    <div class="space-y-4 bg-neutral-900 p-6 rounded-md border border-neutral-700">

        <!-- Zone Name -->
        <div>
            <label class="block text-sm font-medium mb-1 text-gray-300">Zone Name *</label>
            <InputText @bind-Value="vm.Name"
                       class="w-full bg-neutral-800 border border-neutral-600 rounded px-3 py-2 text-amber-600" />
        </div>

        <!-- Base Cost -->
        <div>
            <label class="block text-sm font-medium mb-1 text-gray-300">Base Cost (€)</label>
            <InputNumber @bind-Value="vm.BaseCost"
                         class="w-full bg-neutral-800 border border-neutral-600 rounded px-3 py-2 text-amber-600" />
        </div>

        <!-- Free Shipping Threshold -->
        <div>
            <label class="block text-sm font-medium mb-1 text-gray-300">Free Shipping Threshold (€)</label>
            <InputNumber @bind-Value="vm.FreeShippingThreshold"
                         class="w-full bg-neutral-800 border border-neutral-600 rounded px-3 py-2 text-amber-600" />
        </div>

        <!-- Default Zone -->
        <div class="flex items-center space-x-2">
            <InputCheckbox @bind-Value="vm.IsDefault" class="accent-amber-600" />
            <span class="text-gray-300">Default Zone</span>
        </div>

        <!-- Countries -->
        <div>
            <label class="block text-sm font-medium mb-2 text-gray-300">Countries</label>

            <!-- Add new country inline -->
            <div class="flex space-x-2 mb-3">
                <InputText @bind-Value="newCountryCode"
                           placeholder="Code (e.g. DE)"
                           class="px-2 py-1 bg-neutral-800 border border-neutral-600 rounded text-amber-600 uppercase" />
                <InputText @bind-Value="newCountryName"
                           placeholder="Name (e.g. Germany)"
                           class="px-2 py-1 bg-neutral-800 border border-neutral-600 rounded text-amber-600" />
                <button type="button"
                        class="bg-amber-600 hover:bg-amber-700 text-white px-3 py-1 rounded"
                        @onclick="AddNewCountry">
                    + Add
                </button>
            </div>

            <!-- Filtered country list -->
            <div class="grid grid-cols-2 gap-2 max-h-64 overflow-y-auto border border-neutral-700 p-2 rounded">
                @foreach (var c in filteredCountries)
                {
                    <label class="flex items-center space-x-2">
                        <input type="checkbox"
                               checked="@vm.Countries.Any(cc => cc.Code == c.Code)"
                               @onchange="e => ToggleCountry(c, (bool)e.Value!)" />
                        <span>@c.Name (@c.Code)</span>
                    </label>
                }
            </div>
        </div>
    </div>

    <!-- Buttons -->
    <div class="flex justify-end space-x-3 mt-6">
        <button type="button"
                class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded"
                @onclick="Cancel">
            Cancel
        </button>
        <button type="submit"
                class="bg-amber-600 hover:bg-amber-700 text-white px-6 py-2 rounded">
            Save
        </button>
    </div>

    @if (!string.IsNullOrEmpty(error))
    {
        <p class="text-red-400 mt-4">@error</p>
    }
</AutoForm>

@code {
    [Parameter] public int? ZoneId { get; set; }

    private ShippingZoneVm vm = new();
    private string? error;
    private List<CountryVm> allCountries = new();
    private List<ShippingZoneVm> allZones = new();
    private List<CountryVm> filteredCountries = new();

    private string newCountryCode = "";
    private string newCountryName = "";

    protected override async Task OnInitializedAsync()
    {
        var token = await AdminAuth.GetTokenAsync();
        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        try
        {
            // Load all zones (to know which countries are taken)
            allZones = await Http.GetFromJsonAsync<List<ShippingZoneVm>>("shipping-zones") ?? new();

            // Load all countries
            allCountries = await Http.GetFromJsonAsync<List<CountryVm>>("shipping-zones/countries") ?? new();

            if (ZoneId != null)
            {
                vm = await Http.GetFromJsonAsync<ShippingZoneVm>($"shipping-zones/{ZoneId}") ?? new();
            }

            ApplyCountryFilter();
        }
        catch (Exception ex)
        {
            error = "⚠️ Failed to load data: " + ex.Message;
        }
    }

    private void ApplyCountryFilter()
    {
        var usedCodes = allZones
            .Where(z => ZoneId == null || z.Id != ZoneId) // exclude current zone
            .SelectMany(z => z.Countries.Select(c => c.Code))
            .ToHashSet();

        filteredCountries = allCountries
            .Where(c => !usedCodes.Contains(c.Code) || vm.Countries.Any(vc => vc.Code == c.Code))
            .OrderBy(c => c.Name)
            .ToList();
    }

    private async Task SaveZone()
    {
        try
        {
            HttpResponseMessage resp;
            if (ZoneId == null)
                resp = await Http.PostAsJsonAsync("shipping-zones", vm);
            else
                resp = await Http.PutAsJsonAsync($"shipping-zones/{ZoneId}", vm);

            if (resp.IsSuccessStatusCode)
                Nav.NavigateTo("/admin?tab=ShippingZones");
            else
                error = await resp.Content.ReadAsStringAsync();
        }
        catch (Exception ex)
        {
            error = "⚠️ Failed to save zone: " + ex.Message;
        }
    }

    private void Cancel() => Nav.NavigateTo("/admin?tab=ShippingZones");

    private void ToggleCountry(CountryVm country, bool selected)
    {
        if (selected && !vm.Countries.Any(cc => cc.Code == country.Code))
            vm.Countries.Add(new CountryVm { Code = country.Code, Name = country.Name });
        else if (!selected)
            vm.Countries.RemoveAll(cc => cc.Code == country.Code);
    }

    private void AddNewCountry()
    {
        if (string.IsNullOrWhiteSpace(newCountryCode) || string.IsNullOrWhiteSpace(newCountryName))
            return;

        var code = newCountryCode.Trim().ToUpperInvariant();

        // Check if already assigned to another zone
        var conflict = allZones
            .FirstOrDefault(z => z.Countries.Any(c => c.Code == code && (ZoneId == null || z.Id != ZoneId)));

        if (conflict != null)
        {
            error = $"⚠️ Country {code} is already assigned to zone '{conflict.Name}'.";
            return;
        }

        if (!allCountries.Any(c => c.Code == code))
        {
            var country = new CountryVm { Code = code, Name = newCountryName.Trim() };
            allCountries.Add(country);
            vm.Countries.Add(country);
        }
        else if (!vm.Countries.Any(c => c.Code == code))
        {
            var country = allCountries.First(c => c.Code == code);
            vm.Countries.Add(country);
        }

        newCountryCode = "";
        newCountryName = "";
        error = null;

        ApplyCountryFilter();
    }

    private class ShippingZoneVm
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public decimal BaseCost { get; set; }
        public decimal FreeShippingThreshold { get; set; }
        public bool IsDefault { get; set; }
        public List<CountryVm> Countries { get; set; } = new();
    }

    private class CountryVm
    {
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
    }
}
