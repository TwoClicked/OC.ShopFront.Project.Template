@page "/account"
@using OC.LUAC.UiLayer.DTO.AdminDash
@using OC.LUAC.UiLayer.DTO.Auth
@using OC.LUAC.UiLayer.DTO.Order
@using OC.LUAC.UiLayer.Services
@inject AuthService AuthService
@inject NavigationManager Nav
@inject Microsoft.Extensions.Localization.IStringLocalizer<Account> L

<section class="min-h-screen bg-neutral-900 text-white p-8">
    <div class="max-w-5xl mx-auto bg-neutral-800 rounded-lg shadow-lg p-6">
        <!-- Tabs -->
        <div class="flex space-x-6 border-b border-neutral-700 mb-6">
            <button class="@GetTabClass("profile")" @onclick='() => SwitchTab("profile")'>@L["Profile"]</button>
            <button class="@GetTabClass("password")" @onclick='() => SwitchTab("password")'>@L["ChangePassword"]</button>
            <button class="@GetTabClass("orders")" @onclick='() => SwitchTab("orders")'>@L["Orders"]</button>
            <button class="@GetTabClass("danger")" @onclick='() => SwitchTab("danger")'>@L["DangerZone"]</button>
        </div>

        <!-- Profile -->
        @if (ActiveTab == "profile")
        {
            @if (profile == null)
            {
                <p>@L["LoadingProfile"]</p>
            }
            else
            {
                <AutoForm Model="@profile" OnValidSubmit="UpdateProfile">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-4">
                        <label class="block text-sm font-medium">@L["FirstName"]</label>
                        <InputText @bind-Value="profile.FirstName"
                                   class="mt-1 w-full rounded-md bg-neutral-900 text-white border border-neutral-700 p-2" />
                    </div>

                    <div class="mb-4">
                        <label class="block text-sm font-medium">@L["LastName"]</label>
                        <InputText @bind-Value="profile.LastName"
                                   class="mt-1 w-full rounded-md bg-neutral-900 text-white border border-neutral-700 p-2" />
                    </div>

                    <div class="mb-4">
                        <label class="block text-sm font-medium">@L["EmailReadonly"]</label>
                        <input value="@profile.Email" disabled
                               class="mt-1 w-full rounded-md bg-neutral-700 text-gray-400 p-2" />
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium">@L["Language"]</label>
                        <InputSelect @bind-Value="profile.Language"
                                     class="mt-1 w-full rounded-md bg-neutral-900 text-white border border-neutral-700 p-2">
                            <option value="en">@L["English"]</option>
                            <option value="de">@L["German"]</option>
                        </InputSelect>
                    </div>

                    <button type="submit"
                            class="w-full bg-amber-600 text-white py-2 px-4 rounded-md hover:bg-amber-700">
                        @L["SaveChanges"]
                    </button>
                </AutoForm>
            }
        }

        <!-- Change Password -->
        @if (ActiveTab == "password")
        {
            <AutoForm Model="@passwordModel" OnValidSubmit="ChangePassword">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-4">
                    <label class="block text-sm font-medium">@L["OldPassword"]</label>
                    <InputText @bind-Value="passwordModel.OldPassword" type="password"
                               class="mt-1 w-full rounded-md bg-neutral-900 text-white border border-neutral-700 p-2" />
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-medium">@L["NewPassword"]</label>
                    <InputText @bind-Value="passwordModel.NewPassword" type="password"
                               class="mt-1 w-full rounded-md bg-neutral-900 text-white border border-neutral-700 p-2" />
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-medium">@L["ConfirmPassword"]</label>
                    <InputText @bind-Value="passwordModel.ConfirmPassword" type="password"
                               class="mt-1 w-full rounded-md bg-neutral-900 text-white border border-neutral-700 p-2" />
                </div>

                <button type="submit"
                        class="w-full bg-amber-600 text-white py-2 px-4 rounded-md hover:bg-amber-700">
                    @L["ChangePassword"]
                </button>
            </AutoForm>
        }

        <!-- Orders -->
        @if (ActiveTab == "orders")
        {
            @if (orders == null)
            {
                <p>@L["LoadingOrders"]</p>
            }
            else if (!orders.Any())
            {
                <p>@L["NoOrders"]</p>
            }
            else
            {
                <table class="w-full text-left border-collapse">
                    <thead class="border-b border-neutral-700 text-gray-400 text-sm">
                        <tr>
                            <th class="py-2 px-4">@L["OrderNumber"]</th>
                            <th class="py-2 px-4">@L["Date"]</th>
                            <th class="py-2 px-4">@L["Total"]</th>
                            <th class="py-2 px-4">@L["Status"]</th>
                            <th class="py-2 px-4">@L["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in orders)
                        {
                            <tr class="border-b border-neutral-800">
                                <td class="py-2 px-4 font-semibold">@order.OrderNumber</td>
                                <td class="py-2 px-4">@order.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td class="py-2 px-4">@order.TotalAfterDiscount.ToString("C", new System.Globalization.CultureInfo("de-DE"))</td>
                                <td class="py-2 px-4">
                                    @if (order.Status == "Cancelled")
                                    {
                                        <span class="text-red-500 font-semibold">@L["Cancelled"]</span>
                                    }
                                    else
                                    {
                                        @order.Status
                                    }
                                </td>
                                <td class="py-2 px-4">
                                    @if (order.Status == "PendingPayment")
                                    {
                                        <button @onclick="() => CancelOrder(order.Id)"
                                                class="bg-red-600 text-white px-3 py-1 text-sm rounded hover:bg-red-700">
                                            @L["Cancel"]
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }

        <!-- Danger Zone -->
        @if (ActiveTab == "danger")
        {
            <div class="space-y-4">
                <p class="text-red-400 text-sm">
                    ⚠️ @L["DangerZoneWarning"]
                </p>

                <input @bind="deleteConfirmation"
                       placeholder='@L["DeletePlaceholder"]'
                       class="w-full rounded-md bg-neutral-900 text-white border border-neutral-700 p-2" />

                <button @onclick="ConfirmDelete"
                        disabled="@(!CanDelete)"
                        class="w-full py-2 px-4 rounded-md transition-colors
                                   @(CanDelete ? "bg-red-600 hover:bg-red-700 text-white" : "bg-neutral-700 text-gray-400 cursor-not-allowed")">
                    @L["DeleteAccount"]
                </button>
            </div>
        }

        @if (!string.IsNullOrEmpty(Message))
        {
            <p class="text-center @MessageCss">@Message</p>
        }
    </div>
</section>

@code {
    private string ActiveTab { get; set; } = "profile";
    private CustomerProfileDto? profile;
    private List<AdminOrderSummaryDto>? orders;
    private ChangePasswordFormDto passwordModel = new();
    private string? Message;
    private string MessageCss { get; set; } = "";

    private string deleteConfirmation = string.Empty;
    private bool CanDelete => deleteConfirmation.Equals("delete", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadProfile();
            await LoadOrders();
            StateHasChanged();
        }
    }

    private async Task LoadProfile()
    {
        profile = await AuthService.GetProfileAsync();
    }

    private async Task LoadOrders()
    {
        var result = await AuthService.GetOrdersAsync();
        if (result != null)
        {
            orders = result
                .OrderBy(o => o.Status == "PendingPayment" ? 0 :
                              o.Status == "Processing" ? 1 :
                              o.Status == "Shipped" ? 2 :
                              o.Status == "Cancelled" ? 3 : 4)
                .ThenByDescending(o => o.CreatedAt)
                .ToList();
        }
    }

    private async Task UpdateProfile()
    {
        if (profile == null) return;

        var updateDto = new UpdateCustomerDto
        {
            FirstName = profile.FirstName,
            LastName = profile.LastName,
            Language = profile.Language
        };

        var success = await AuthService.UpdateProfileAsync(updateDto);
        Message = success ? L["ProfileUpdated"] : L["ProfileUpdateFailed"];
        MessageCss = success ? "text-green-500" : "text-red-500";
    }

    private async Task ChangePassword()
    {
        if (passwordModel.NewPassword != passwordModel.ConfirmPassword)
        {
            Message = L["PasswordMismatch"];
            MessageCss = "text-red-500";
            return;
        }

        var dto = new ChangePasswordFormDto
        {
            OldPassword = passwordModel.OldPassword,
            NewPassword = passwordModel.NewPassword
        };

        var success = await AuthService.ChangePasswordAsync(dto);
        if (success)
        {
            Message = L["PasswordChanged"];
            MessageCss = "text-green-500";
        }
        else
        {
            Message = L["PasswordChangeFailed"];
            MessageCss = "text-red-500";
        }
        passwordModel = new(); // reset form
    }

    private async Task ConfirmDelete()
    {
        if (!CanDelete) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm", L["ConfirmDeletePrompt"]);
        if (confirmed)
        {
            await DeleteAccount();
        }
    }

    private async Task DeleteAccount()
    {
        var success = await AuthService.DeleteAccountAsync();
        if (success)
        {
            await AuthService.LogoutAsync();
            Nav.NavigateTo("/", forceLoad: true);
        }
        else
        {
            Message = L["DeleteFailed"];
            MessageCss = "text-red-500";
        }
    }

    private async Task CancelOrder(int orderId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", L["ConfirmCancelOrder"]);
        if (confirmed)
        {
            var success = await AuthService.CancelOrderAsync(orderId);
            if (success)
            {
                await LoadOrders();
                StateHasChanged();
            }
            else
            {
                Message = L["CancelFailed"];
                MessageCss = "text-red-500";
            }
        }
    }

    private void SwitchTab(string tab)
    {
        ActiveTab = tab;
        Message = null;
    }

    private string GetTabClass(string tab) =>
        ActiveTab == tab
            ? "pb-2 text-amber-500 font-semibold border-b-2 border-amber-500"
            : "pb-2 text-gray-400 hover:text-white";

    [Inject] private IJSRuntime JS { get; set; } = default!;
}
