@page "/reset-password"
@inject NavigationManager Nav
@inject HttpClient Http

<section class="min-h-screen flex items-center justify-center bg-neutral-900 text-white">
    <div class="bg-neutral-900 p-8 rounded-lg shadow-lg w-full max-w-md">
        <h2 class="text-xl font-semibold mb-6 text-center">Reset Password</h2>

        <AutoForm Model="@model" OnValidSubmit="HandleReset">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-4">
                <label class="block text-sm font-medium">New Password</label>
                <InputText @bind-Value="model.NewPassword" type="password"
                           class="mt-1 w-full rounded-md bg-neutral-900 text-white border border-neutral-700 p-2" />
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium">Confirm Password</label>
                <InputText @bind-Value="model.ConfirmPassword" type="password"
                           class="mt-1 w-full rounded-md bg-neutral-900 text-white border border-neutral-700 p-2" />
            </div>

            <button type="submit"
                    class="w-full bg-amber-600 text-white py-2 px-4 rounded-md hover:bg-amber-700">
                Reset Password
            </button>
        </AutoForm>

        @if (!string.IsNullOrEmpty(Message))
        {
            <p class="mt-4 text-center @(IsSuccess ? "text-green-500" : "text-red-500")">@Message</p>
        }
    </div>
</section>

@code {
    private ResetPasswordDto model = new();
    private string? Message;
    private bool IsSuccess;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("token", out var t))
        {
            model.Token = t!; // ✅ assign token directly to the model
        }
    }

    private async Task HandleReset()
    {
        if (string.IsNullOrEmpty(model.Token))
        {
            Message = "Invalid or missing reset token.";
            IsSuccess = false;
            return;
        }

        var response = await Http.PostAsJsonAsync("customers/reset-password", model);

        if (response.IsSuccessStatusCode)
        {
            // ✅ Set message first
            Message = "✅ Your password has been reset successfully! You will be redirected to the login page.";
            IsSuccess = true;
            StateHasChanged(); // force UI update

            // wait so the user sees the message
            await Task.Delay(3000);

            // redirect after showing message
            Nav.NavigateTo("/loginRegister", forceLoad: true);
        }
        else
        {
            var body = await response.Content.ReadAsStringAsync();

            if (body.Contains("Passwords do not match", StringComparison.OrdinalIgnoreCase))
                Message = "❌ Passwords do not match.";
            else if (body.Contains("Token", StringComparison.OrdinalIgnoreCase))
                Message = "❌ Invalid or expired reset link.";
            else
                Message = "❌ Reset failed. Please try again.";

            IsSuccess = false;
            StateHasChanged();
        }
    }
}
