@page "/reset-password"
@inject NavigationManager Nav
@inject HttpClient Http
@inject Microsoft.Extensions.Localization.IStringLocalizer<ResetPassword> L
<section class="min-h-screen flex items-center justify-center bg-neutral-900 text-white">
    <div class="bg-neutral-900 p-8 rounded-lg shadow-lg w-full max-w-md">
        <h2 class="text-xl font-semibold mb-6 text-center">@L["Header"]</h2>
        <AutoForm Model="@model" OnValidSubmit="HandleReset">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="mb-4">
                <label class="block text-sm font-medium">@L["NewPassword"]</label>
                <InputText @bind-Value="model.NewPassword" type="password"
                           class="mt-1 w-full rounded-md bg-neutral-900 text-white border border-neutral-700 p-2" />
            </div>
            <div class="mb-6">
                <label class="block text-sm font-medium">@L["ConfirmPassword"]</label>
                <InputText @bind-Value="model.ConfirmPassword" type="password"
                           class="mt-1 w-full rounded-md bg-neutral-900 text-white border border-neutral-700 p-2" />
            </div>
            <button type="submit"
                    class="w-full bg-amber-600 text-white py-2 px-4 rounded-md hover:bg-amber-700">
                @L["ResetButton"]
            </button>
        </AutoForm>
        @if (!string.IsNullOrEmpty(Message))
        {
            <p class="mt-4 text-center @(IsSuccess ? "text-green-500" : "text-red-500")">@Message</p>
        }
    </div>
</section>
@code {
    private ResetPasswordDto model = new();
    private string? Message;
    private bool IsSuccess;
    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("token", out var t))
        {
            model.Token = t!;
        }
    }
    private async Task HandleReset()
    {
        if (string.IsNullOrEmpty(model.Token))
        {
            Message = L["InvalidOrMissingToken"];
            IsSuccess = false;
            return;
        }
        var response = await Http.PostAsJsonAsync("customers/reset-password", model);
        if (response.IsSuccessStatusCode)
        {
            Message = L["SuccessMessage"];
            IsSuccess = true;
            StateHasChanged();
            await Task.Delay(3000);
            Nav.NavigateTo("/loginRegister", forceLoad: true);
        }
        else
        {
            var body = await response.Content.ReadAsStringAsync();
            if (body.Contains("Passwords do not match", StringComparison.OrdinalIgnoreCase))
                Message = L["PasswordsDoNotMatch"];
            else if (body.Contains("Token", StringComparison.OrdinalIgnoreCase))
                Message = L["InvalidOrExpired"];
            else
                Message = L["GenericError"];
            IsSuccess = false;
            StateHasChanged();
        }
    }
}
