@page "/checkout"
@using System.ComponentModel.DataAnnotations
@using OC.LUAC.ObjectLayer.Orders
@using OC.LUAC.UiLayer.Services
@using OC.LUAC.UiLayer.DTO.Checkout
@using OC.LUAC.ApiLayer.DTO.Shipping
@inject CartService Cart
@inject OrderService Orders
@inject ShippingService Shipping
@inject NavigationManager Nav
@inject HttpClient Http
@inject Microsoft.Extensions.Localization.IStringLocalizer<OC.LUAC.UiLayer.Components.Pages.Checkout> L

<section class="py-16 px-6 md:px-12 text-white">
    <h2 class="text-3xl font-bold mb-10 text-center">@L["Title"]</h2>

    @if (!Cart.Items.Any())
    {
        <p class="text-center text-gray-400">@L["CartEmpty"]</p>
        <div class="text-center mt-6">
            <a href="/shop" class="px-5 py-3 bg-amber-600 rounded hover:bg-amber-700">@L["BackToShop"]</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 max-w-7xl mx-auto">
            <!-- Left: Addresses -->
            <div class="lg:col-span-2 space-y-10">
                <AutoForm Model="@vm" OnValidSubmit="@Submit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-red-400 mb-4" />

                    <!-- Shipping -->
                    <div class="bg-neutral-800 rounded-xl p-6">
                        <h3 class="text-xl font-semibold mb-4">@L["ShippingAddress"]</h3>
                        @AddressForm(vm.Shipping, "shipping")
                    </div>

                    <!-- Billing same as shipping -->
                    <div class="flex items-center gap-2">
                        <input type="checkbox" class="accent-amber-600" @bind="vm.BillingSameAsShipping" />
                        <label>@L["BillingSameAsShipping"]</label>
                    </div>

                    <!-- Billing -->
                    @if (!vm.BillingSameAsShipping)
                    {
                        <div class="bg-neutral-800 rounded-xl p-6">
                            <h3 class="text-xl font-semibold mb-4">@L["BillingAddress"]</h3>
                            @AddressForm(vm.Billing, "billing")
                        </div>
                    }

                    <!-- Place order -->
                    <button type="submit"
                            class="px-6 py-3 bg-amber-600 rounded text-white font-bold hover:bg-amber-700"
                            disabled="@isSubmitting">
                        @(isSubmitting? L["PlacingOrder"] : L["PlaceOrder"])
                    </button>

                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="mt-4 text-red-400">@error</div>
                    }
                </AutoForm>
            </div>

            <!-- Right: Order Summary -->
            <div>
                <div class="bg-neutral-800 rounded-xl p-6">
                    <h3 class="text-xl font-semibold mb-4">@L["OrderSummary"]</h3>

                    <ul class="divide-y divide-neutral-700">
                        @foreach (var x in Cart.Items)
                        {
                            <li class="py-3 flex items-center gap-3">
                                @if (!string.IsNullOrWhiteSpace(x.ThumbnailUrl))
                                {
                                    <img src="@x.ThumbnailUrl" class="w-14 h-14 object-cover rounded" />
                                }
                                <div class="flex-1">
                                    <div class="font-medium">@x.ProductName</div>
                                    <div class="text-sm text-gray-400">@L["Size"]: @x.Size</div>
                                    <div class="text-sm text-gray-400">@L["Quantity"]: @x.Quantity</div>
                                </div>
                                <div class="text-sm">@((x.Price * x.Quantity).ToString("C", new System.Globalization.CultureInfo("de-DE")))</div>
                            </li>
                        }
                    </ul>

                    <!-- Voucher input -->
                    <div class="mt-4 border-t border-neutral-700 pt-4">
                        <label class="block mb-1">@L["VoucherCode"]</label>
                        <div class="flex gap-2">
                            <InputText @bind-Value="voucherCode"
                                       class="flex-1 min-w-0 bg-neutral-900 border border-neutral-700 rounded-l p-2" />
                            <button type="button"
                                    class="px-4 py-2 bg-neutral-700 rounded-r hover:bg-amber-700 whitespace-nowrap"
                                    @onclick="ApplyVoucher">
                                @L["Apply"]
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(voucherError))
                        {
                            <p class="text-red-400 text-sm mt-1">@voucherError</p>
                        }
                        @if (voucherDiscount > 0 && !appliesToShipping)
                        {
                            <div class="flex justify-between mt-2 text-green-400">
                                <span>@L["Discount"]</span>
                                <span>-@voucherDiscount.ToString("C", new System.Globalization.CultureInfo("de-DE"))</span>
                            </div>
                        }
                        @if (voucherDiscount > 0 && appliesToShipping)
                        {
                            <div class="flex justify-between mt-2 text-green-400">
                                <span>@L["VoucherAndFreeShipping"]</span>
                                <span>-@voucherDiscount.ToString("C", new System.Globalization.CultureInfo("de-DE"))</span>
                            </div>
                        }
                    </div>

                    <!-- Shipping line -->
                    <div class="border-t border-neutral-700 mt-4 pt-4 flex justify-between">
                        <span class="font-semibold">@L["Shipping"]</span>

                        @if (quote is null)
                        {
                            <span class="text-gray-400">—</span>
                        }
                        else if (quote.IsFree || appliesToShipping)
                        {
                            <span class="text-amber-500">@L["Free"]</span>
                        }
                        else
                        {
                            <span>@quote.ShippingCost.ToString("C", new System.Globalization.CultureInfo("de-DE"))</span>
                        }
                    </div>

                    <!-- Grand total -->
                    <div class="flex justify-between font-semibold border-t border-neutral-700 pt-2">
                        <span>@L["Total"]</span>
                        <span class="text-amber-600">@GrandTotal.ToString("C", new System.Globalization.CultureInfo("de-DE"))</span>
                    </div>

                    @if (quote is not null && !quote.IsFree)
                    {
                        <p class="text-xs text-gray-400 mt-2">
                            @L["FreeShippingThreshold", quote.FreeShippingThreshold.ToString("C", new System.Globalization.CultureInfo("de-DE"))]
                        </p>
                    }
                </div>
            </div>
        </div>
    }
</section>

@code {
    private CheckoutVm vm = new();
    private string? error;
    private ShippingQuote? quote;
    private bool isSubmitting = false;

    private string voucherCode = "";
    private decimal voucherDiscount = 0m;
    private string? voucherError;
    private bool appliesToShipping = false;

    private decimal CartSubtotal => Cart.GetTotal();
    private decimal GrandTotal => Math.Max(0, CartSubtotal + (quote?.ShippingCost ?? 0) - voucherDiscount);

    private List<CountryDto> Countries = new();

    private string _selectedCountry = "";
    private string SelectedCountry
    {
        get => _selectedCountry;
        set
        {
            _selectedCountry = value;
            vm.Shipping.Country = value;
            _ = UpdateQuote();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Countries = await Shipping.GetCountriesAsync();

            if (!string.IsNullOrWhiteSpace(vm.Shipping.Country))
                await UpdateQuote();
        }
        catch (Exception ex)
        {
            Console.WriteLine("❌ Failed to load countries: " + ex.Message);
        }
    }

    private async Task Submit()
    {
        if (isSubmitting) return;

        error = null;

        var oos = Cart.Items.FirstOrDefault(i => i.MaxStock <= 0 || i.Quantity > i.MaxStock);
        if (oos is not null)
        {
            error = L["OutOfStockError", oos.ProductName];
            return;
        }

        await UpdateQuote();
        if (quote is null)
        {
            error = L["SelectCountryError"];
            return;
        }

        isSubmitting = true;

        try
        {
            var payload = new CheckoutRequestDto
            {
                Shipping = vm.Shipping,
                Billing = vm.BillingSameAsShipping ? null : vm.Billing,
                Items = Cart.Items.Select(i => new CheckoutItemDto
                {
                    ProductId = i.ProductId,
                    ProductVariantId = i.ProductVariantId,
                    Size = i.Size,
                    Price = i.Price,
                    Quantity = i.Quantity
                }).ToList(),
                VoucherCode = string.IsNullOrWhiteSpace(voucherCode) ? null : voucherCode
            };

            var resp = await Orders.PlaceOrderAsync(payload);
            await Cart.ClearCart();
            Nav.NavigateTo($"/thank-you/{Uri.EscapeDataString(resp.OrderId)}");
        }
        catch (Exception ex)
        {
            error = L["PlaceOrderError"];
            Console.WriteLine("❌ " + ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task UpdateQuote()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(vm.Shipping.Country))
            {
                quote = null;
                return;
            }

            quote = await Shipping.GetQuoteAsync(vm.Shipping.Country, CartSubtotal);

            if (appliesToShipping)
            {
                await ApplyVoucher();
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine("❌ Failed to load shipping quote: " + ex.Message);
            quote = null;
        }
    }

    private async Task ApplyVoucher()
    {
        voucherError = null;
        voucherDiscount = 0;
        appliesToShipping = false;

        if (string.IsNullOrWhiteSpace(voucherCode))
        {
            voucherError = L["EnterVoucherError"];
            return;
        }

        try
        {
            var voucher = await Http.GetFromJsonAsync<VoucherResult>($"/api/vouchers/validate/{voucherCode}");
            if (voucher == null)
            {
                voucherError = L["InvalidVoucher"];
                return;
            }

            if (voucher.Percentage.HasValue)
                voucherDiscount += CartSubtotal * (voucher.Percentage.Value / 100m);

            if (voucher.FixedAmount.HasValue)
                voucherDiscount += voucher.FixedAmount.Value;

            if (voucher.AppliesToShipping && quote is not null && !quote.IsFree)
            {
                appliesToShipping = true;
                voucherDiscount += quote.ShippingCost;
            }
        }
        catch
        {
            voucherError = L["InvalidVoucher"];
        }
    }

    private class VoucherResult
    {
        public string Code { get; set; } = "";
        public decimal? Percentage { get; set; }
        public decimal? FixedAmount { get; set; }
        public bool AppliesToShipping { get; set; }
    }

    private class CheckoutVm
    {
        public AddressDto Shipping { get; set; } = new();
        public AddressDto Billing { get; set; } = new();
        public bool BillingSameAsShipping { get; set; } = true;
    }

    private RenderFragment AddressForm(AddressDto model, string idPrefix) => @<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
        <label class="block mb-1">@L["FirstName"]*</label>
        <InputText class="w-full bg-neutral-900 border border-neutral-700 rounded p-2"
                   @bind-Value="model.FirstName" id="@($"{idPrefix}-first")" />
        <ValidationMessage For="@(() => model.FirstName)" />
    </div>
    <div>
        <label class="block mb-1">@L["LastName"]*</label>
        <InputText class="w-full bg-neutral-900 border border-neutral-700 rounded p-2"
                   @bind-Value="model.LastName" id="@($"{idPrefix}-last")" />
        <ValidationMessage For="@(() => model.LastName)" />
    </div>

    <div class="md:col-span-2">
        <label class="block mb-1">@L["Email"]*</label>
        <InputText class="w-full bg-neutral-900 border border-neutral-700 rounded p-2"
                   @bind-Value="model.Email" id="@($"{idPrefix}-email")" />
        <ValidationMessage For="@(() => model.Email)" />
    </div>

    <div class="md:col-span-2">
        <label class="block mb-1">@L["AddressLine1"]*</label>
        <InputText class="w-full bg-neutral-900 border border-neutral-700 rounded p-2"
                   @bind-Value="model.Line1" id="@($"{idPrefix}-line1")" />
        <ValidationMessage For="@(() => model.Line1)" />
    </div>

    <div class="md:col-span-2">
        <label class="block mb-1">@L["AddressLine2"] (@L["Optional"])</label>
        <InputText class="w-full bg-neutral-900 border border-neutral-700 rounded p-2"
                   @bind-Value="model.Line2" id="@($"{idPrefix}-line2")" />
    </div>

    <div>
        <label class="block mb-1">@L["City"]*</label>
        <InputText class="w-full bg-neutral-900 border border-neutral-700 rounded p-2"
                   @bind-Value="model.City" id="@($"{idPrefix}-city")" />
        <ValidationMessage For="@(() => model.City)" />
    </div>
    <div>
        <label class="block mb-1">@L["PostalCode"]*</label>
        <InputText class="w-full bg-neutral-900 border border-neutral-700 rounded p-2"
                   @bind-Value="model.PostalCode" id="@($"{idPrefix}-postal")" />
        <ValidationMessage For="@(() => model.PostalCode)" />
    </div>

    <!-- ✅ Dropdown for country -->
    <div class="md:col-span-2">
        <label class="block mb-1">@L["Country"]*</label>
        <InputSelect class="w-full bg-neutral-900 border border-neutral-700 rounded p-2"
                     @bind-Value="SelectedCountry">
            <option value="">-- @L["SelectCountry"] --</option>
            @foreach (var c in Countries)
                        {
            <option value="@c.Code">@c.Name</option>
                        }
        </InputSelect>
        <ValidationMessage For="@(() => model.Country)" />
    </div>
</div>;
}
