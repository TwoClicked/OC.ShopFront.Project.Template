@page "/forgot-password"
@inject AuthService AuthService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject Microsoft.Extensions.Localization.IStringLocalizer<ForgotPassword> L

<h2 class="text-xl mb-4">@L["Header"]</h2>
<AutoForm Model="@model" OnValidSubmit="SendRequest">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="mb-4">
        <label class="block text-sm font-medium">@L["Email"]</label>
        <InputText @bind-Value="model.Email"
                   type="email"
                   class="mt-1 w-full rounded-md bg-neutral-900 text-white border border-neutral-700 p-2" />
        <ValidationMessage For="@(() => model.Email)" class="text-red-500 text-sm" />
    </div>
    <button type="submit"
            class="bg-amber-600 text-white py-2 px-4 rounded-md hover:bg-amber-700 disabled:opacity-50 disabled:cursor-not-allowed"
            disabled="@(isSubmitting || cooldown > 0 ? true : null)">
        @(
                cooldown > 0
                ? string.Format(L["TryAgainIn"], cooldown / 60, cooldown % 60)
                : (isSubmitting ? L["Sending"] : L["SendResetLink"])
                )
    </button>
</AutoForm>
<p class="mt-4">@Message</p>

@code {
    private ForgotPasswordDto model = new();
    private string? Message;
    private bool isSubmitting = false;
    private int cooldown = 0;
    private System.Threading.Timer? timer;
    private bool _jsInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_jsInitialized)
        {
            _jsInitialized = true;
            try
            {
                var lastRequest = await JS.InvokeAsync<string>("localStorage.getItem", "forgotPwdCooldown");
                if (!string.IsNullOrEmpty(lastRequest) &&
                    DateTime.TryParse(lastRequest, null,
                        System.Globalization.DateTimeStyles.AdjustToUniversal, out var lastTime))
                {
                    var elapsed = (int)(DateTime.UtcNow - lastTime).TotalSeconds;
                    cooldown = Math.Clamp(300 - elapsed, 0, 300);
                    if (cooldown > 0)
                    {
                        StartCooldownTimer();
                    }
                }
                else
                {
                    cooldown = 0;
                }
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine("❌ Failed to access localStorage: " + ex.Message);
            }
        }
    }
    private async Task SendRequest()
    {
        if (isSubmitting || cooldown > 0)
            return;
        isSubmitting = true;
        try
        {
            await AuthService.ForgotPasswordAsync(model.Email);
            Message = L["IfExistsMessage"];
            cooldown = 300;
            await JS.InvokeVoidAsync("localStorage.setItem", "forgotPwdCooldown", DateTime.UtcNow.ToString("o"));
            StartCooldownTimer();
        }
        catch (Exception)
        {
            Message = L["GenericError"];
        }
        finally
        {
            isSubmitting = false;
        }
    }
    private void StartCooldownTimer()
    {
        timer = new System.Threading.Timer(_ =>
        {
            if (cooldown > 0)
            {
                cooldown--;
                InvokeAsync(StateHasChanged);
            }
            else
            {
                timer?.Dispose();
                timer = null;
            }
        }, null, 1000, 1000);
    }
    public void Dispose()
    {
        timer?.Dispose();
    }
}
