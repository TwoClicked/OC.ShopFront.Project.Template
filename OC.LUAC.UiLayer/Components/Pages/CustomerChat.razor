@page "/chat"
@inject ChatClientService ChatClient
@inject AuthService Auth
@inject Microsoft.Extensions.Localization.IStringLocalizer<CustomerChat> L

<h2 class="text-2xl font-bold mb-4 text-amber-600">@L["LiveChat"]</h2>

@if (!started)
{
    @if (hasActiveChat)
    {
        <button @onclick="ResumeSession"
                class="bg-green-600 text-white px-4 py-2 rounded">
            @resumeButtonLabel
        </button>
    }
    else
    {
        <button @onclick="StartSession"
                class="bg-amber-600 text-white px-4 py-2 rounded">
            @L["StartChat"]
        </button>
    }
}
else
{
    <div class="border border-neutral-700 p-3 rounded bg-neutral-900 max-h-80 overflow-y-auto mb-3">
        @foreach (var msg in messages)
        {
            <div class="mb-2 @(msg.IsSystem
                                                  ? "text-gray-400"
                                                  : msg.IsFromCustomer ? "text-amber-600" : "text-green-400")">
                                                                                                            <strong>
                    @(msg.IsSystem
                                ? "[System]"
                                : msg.IsFromCustomer ? L["You"] : L["Admin"]):
        </strong> @msg.Text
    </div>
        }
    </div>

    @if (!sessionClosed)
    {
        <div class="flex space-x-2">
            <input type="text"
                   @bind="currentMessage"
                   @bind:event="oninput"
                   placeholder="@L["TypeMessage"]"
                   class="flex-grow bg-neutral-800 border border-neutral-600 rounded px-3 py-2 text-white"
                   @onkeydown="HandleKeyPress" />
            <button @onclick="SendMessage"
                    class="bg-amber-600 text-white px-4 py-2 rounded">
                @L["Send"]
            </button>
        </div>
    }
    else
    {
        <div class="text-red-400 font-semibold">⚠️ @L["SessionClosedByAdmin"]</div>
    }
}

@code {
    private int sessionId;
    private bool started = false;
    private bool sessionClosed = false;
    private string currentMessage = "";
    private readonly List<ChatVm> messages = new();
    private bool initialized = false;
    private string? token;

    private bool hasActiveChat = false;
    private string resumeButtonLabel = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !initialized)
        {
            initialized = true;

            token = await Auth.GetTokenAsync();
            if (string.IsNullOrWhiteSpace(token))
            {
                messages.Add(new ChatVm
                {
                    Text = $"⚠️ {L["MustBeLoggedIn"]}",
                    IsSystem = true
                });
                StateHasChanged();
                return;
            }

            await ChatClient.ConnectAsync(token);

            ChatClient.OnMessageReceived += async (msg) =>
            {
                await InvokeAsync(() =>
                {
                    messages.Add(new ChatVm
                    {
                        Text = msg.Message ?? "",
                        IsFromCustomer = msg.IsFromCustomer
                    });
                    StateHasChanged();
                });
            };

            ChatClient.OnSessionClosed += async (closedSessionId) =>
            {
                if (sessionId == closedSessionId)
                {
                    await InvokeAsync(() =>
                    {
                        sessionClosed = true;
                        messages.Add(new ChatVm
                        {
                            Text = $"⚠️ {L["SessionClosed"]}",
                            IsSystem = true
                        });
                        StateHasChanged();
                    });
                }
            };

            // 🔎 Check if user already has a chat session
            try
            {
                var history = await ChatClient.GetMyMessagesAsync(token);
                if (history != null && history.Any())
                {
                    hasActiveChat = true;

                    var last = history.Last();
                    resumeButtonLabel = last.IsFromCustomer
                        ? L["ResumeChat"]
                        : L["AdminHasReplied"];
                }
            }
            catch (Exception ex)
            {
                messages.Add(new ChatVm
                {
                    Text = $"⚠️ {L["LoadHistoryError", ex.Message]}",
                    IsSystem = true
                });
            }

            StateHasChanged();
        }
    }

    private async Task StartSession()
    {
        if (string.IsNullOrWhiteSpace(token))
        {
            messages.Add(new ChatVm { Text = $"⚠️ {L["MustBeLoggedIn"]}", IsSystem = true });
            return;
        }

        sessionId = await ChatClient.StartSessionAsync(token);
        started = true;
        sessionClosed = false;

        messages.Add(new ChatVm
        {
            Text = $"💬 {L["AdminWillCheck24h"]}",
            IsSystem = true
        });

        StateHasChanged();
    }

    private async Task ResumeSession()
    {
        if (string.IsNullOrWhiteSpace(token))
        {
            messages.Add(new ChatVm { Text = $"⚠️ {L["MustBeLoggedIn"]}", IsSystem = true });
            return;
        }

        sessionId = await ChatClient.StartSessionAsync(token);
        started = true;
        sessionClosed = false;

        var history = await ChatClient.GetMyMessagesAsync(token);
        if (history != null)
        {
            foreach (var h in history)
            {
                messages.Add(new ChatVm
                {
                    Text = h.Message,
                    IsFromCustomer = h.IsFromCustomer
                });
            }
        }

        StateHasChanged();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(currentMessage)) return;

        var text = currentMessage.Trim();
        currentMessage = "";

        messages.Add(new ChatVm
        {
            Text = text,
            IsFromCustomer = true
        });
        StateHasChanged();

        await ChatClient.SendMessageAsync(sessionId, text);
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private class ChatVm
    {
        public string Text { get; set; } = "";
        public bool IsFromCustomer { get; set; }
        public bool IsSystem { get; set; }
    }
}
