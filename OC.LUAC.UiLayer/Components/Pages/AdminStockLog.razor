@page "/admin/stock/log/{VariantId:int}"
@using System.Net.Http.Json
@inject HttpClient Http
@inject AdminAuthService AdminAuth
@inject NavigationManager Nav
@inject Microsoft.Extensions.Localization.IStringLocalizer<AdminStockLog> L

<h2 class="text-2xl font-bold mb-6 text-amber-600">@L["Title"]</h2>
@if (logs == null)
{
    <p class="text-gray-400">@L["LoadingLogs"]</p>
}
else if (!logs.Any())
{
    <p class="text-gray-400">@L["NoLogs"]</p>
}
else
{
    <table class="w-full text-center border-collapse">
        <thead class="bg-neutral-800 text-gray-400 uppercase text-xs">
            <tr>
                <th class="px-3 py-2">@L["Action"]</th>
                <th class="px-3 py-2">@L["Quantity"]</th>
                <th class="px-3 py-2">@L["Timestamp"]</th>
                <th class="px-3 py-2">@L["Order"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in PagedLogs)
            {
                <tr class="border-b border-neutral-700">
                    <td class="px-3 py-2">@a.ActionType</td>
                    <td class="px-3 py-2">@a.Quantity</td>
                    <td class="px-3 py-2">@a.Timestamp.ToLocalTime().ToString("g")</td>
                    <td class="px-3 py-2">@a.OrderId</td>
                </tr>
            }
        </tbody>
    </table>
    <!-- Pagination -->
    <div class="flex justify-between items-center mt-6">
        <div class="flex space-x-2">
            <button class="px-3 py-1 rounded bg-neutral-800 text-gray-300 hover:bg-neutral-700"
                    disabled="@(page == 1)"
                    @onclick="PrevPage">
                @L["Prev"]
            </button>
            <button class="px-3 py-1 rounded bg-neutral-800 text-gray-300 hover:bg-neutral-700"
                    disabled="@(page >= TotalPages)"
                    @onclick="NextPage">
                @L["Next"]
            </button>
        </div>
        <!-- Page Size Selector -->
        <select class="bg-neutral-800 text-gray-300 px-2 py-1 rounded"
                @onchange="ChangePageSize">
            @foreach (var size in PageSizes)
            {
                <option value="@size" selected="@(pageSize == size)">@L["PerPage", size]</option>
            }
        </select>
    </div>
}
<!-- Back Button -->
<div class="mt-6">
    <button class="bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded"
            @onclick="@(() => Nav.NavigateTo("/admin?tab=Stock"))">
        @L["Back"]
    </button>
</div>
@code {
    [Parameter] public int VariantId { get; set; }
    private List<StockActionVm>? logs;
    private int page = 1;
    private int pageSize = 10;
    private readonly int[] PageSizes = new[] { 10, 20, 50, 100 };
    private IEnumerable<StockActionVm> PagedLogs =>
        logs?.Skip((page - 1) * pageSize).Take(pageSize) ?? Enumerable.Empty<StockActionVm>();
    private int TotalPages => logs == null || logs.Count == 0
        ? 1
        : (int)Math.Ceiling(logs.Count / (double)pageSize);
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var token = await AdminAuth.GetTokenAsync();
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            logs = await Http.GetFromJsonAsync<List<StockActionVm>>($"stock/variant/{VariantId}/log");
        }
        catch (Exception ex)
        {
            Console.WriteLine("⚠️ Failed to load stock log: " + ex.Message);
            logs = new();
        }
    }
    private void PrevPage()
    {
        if (page > 1) page--;
    }
    private void NextPage()
    {
        if (page < TotalPages) page++;
    }
    private void ChangePageSize(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            pageSize = size;
            page = 1; // reset to first page
        }
    }
    private class StockActionVm
    {
        public string ActionType { get; set; } = "";
        public int Quantity { get; set; }
        public DateTime Timestamp { get; set; }
        public int? OrderId { get; set; }
    }
}
