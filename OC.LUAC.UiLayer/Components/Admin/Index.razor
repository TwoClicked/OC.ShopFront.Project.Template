@page "/admin"
@inject NavigationManager Nav


<h1 class="text-3xl font-bold mb-6">Admin Back Office</h1>

<!-- Tabs -->
<div class="border-b border-neutral-700 mb-6">
    <nav class="flex space-x-6">
        @foreach (var tab in tabs)
        {
            <button @onclick="() => SetActiveTab(tab)"
                    class="pb-2 px-1 border-b-2 transition-colors duration-200 @(activeTab == tab ? "border-amber-500 text-amber-500 font-semibold" : "border-transparent text-gray-400 hover:text-white")">
                @tab
            </button>
        }
    </nav>
</div>

<!-- Tab Content -->
<div>
    @switch (activeTab)
    {
        case "Dashboard":
            <AdminDashboardTab />
            break;
        case "Customers":
            <AdminCustomersTab />
            break;
        case "Products":
            <AdminProductsTab />
            break;
        case "Vouchers":
            <AdminVouchersTab />
            break;
        case "Chat":
            <AdminChatTab />
            break;
        case "ShippingZones":
            <AdminShippingZoneTab />
            break;
        case "Stock":
            <AdminStockTab />
            break;
    }
</div>

@code {
    private string activeTab = "Dashboard";
    private readonly List<string> tabs = new()
{
    "Dashboard", "Customers", "Products", "Stock", "Vouchers", "ShippingZones", "Chat"
};


    private void SetActiveTab(string tab) => activeTab = tab;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query)
            .TryGetValue("tab", out var tab))
        {
            activeTab = tab;
        }
    }

}
