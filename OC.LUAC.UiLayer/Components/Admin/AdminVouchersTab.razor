@using OC.LUAC.ObjectLayer.Orders
@inject IConfiguration Config
@inject HttpClient Http
@inject AdminAuthService AdminAuth
@inject NavigationManager Nav
@attribute [Authorize(Roles = "Admin")]
@inject IJSRuntime JS
@inject Microsoft.Extensions.Localization.IStringLocalizer<AdminVouchersTab> L

<h2 class="text-2xl font-bold mb-6 text-amber-600">@L["VouchersTitle"]</h2>
<!-- Toolbar -->
<div class="flex justify-between items-center mb-4 space-x-4">
    <input type="text"
           @bind="searchTerm"
           @bind:event="oninput"
           placeholder="@L["SearchVouchers"]"
           class="px-4 py-2 rounded-md bg-neutral-800 border border-neutral-600 text-amber-600 placeholder-gray-500 w-1/3" />
    <select class="px-3 py-2 rounded-md bg-neutral-800 border border-neutral-600 text-amber-600"
            @onchange="OnStatusChanged">
        <option value="">@L["AllStatus"]</option>
        <option value="true">@L["Active"]</option>
        <option value="false">@L["Inactive"]</option>
    </select>
    <button class="bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded"
            @onclick='() => Nav.NavigateTo("/admin/vouchers/new")'>
        @L["AddVoucherButton"]
    </button>
</div>
@if (pagedVouchers == null)
{
    <p class="text-gray-400">@L["LoadingVouchers"]</p>
}
else if (!pagedVouchers.Any())
{
    <p class="text-gray-400">@L["NoVouchers"]</p>
}
else
{
    <table class="w-full text-center border-collapse">
        <thead class="bg-neutral-900 text-gray-400 uppercase text-xs">
            <tr>
                <th class="px-3 py-2">@L["Code"]</th>
                <th class="px-3 py-2">@L["Type"]</th>
                <th class="px-3 py-2">@L["Usage"]</th>
                <th class="px-3 py-2">@L["Remaining"]</th>
                <th class="px-3 py-2">@L["Expires"]</th>
                <th class="px-3 py-2">@L["Status"]</th>
                <th class="px-3 py-2">@L["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in pagedVouchers)
            {
                <tr class="border-b border-neutral-700">
                    <td class="px-3 py-2">@v.Code</td>
                    <td class="px-3 py-2">
                        @if (v.Percentage.HasValue)
                        {
                            <span>@L["PercentageOff", v.Percentage]</span>
                        }
                        else if (v.FixedAmount.HasValue)
                        {
                            <span>@L["FixedOff", v.FixedAmount.Value.ToString("C", new System.Globalization.CultureInfo("de-DE"))]</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                        @if (v.AppliesToShipping)
                        {
                            <span class="ml-1 text-amber-500">(@L["FreeShip"])</span>
                        }
                    </td>
                    <td class="px-3 py-2">@v.CurrentUsageCount / @(v.MaxUsageCount?.ToString() ?? "∞")</td>
                    <td class="px-3 py-2">@((v.MaxUsageCount.HasValue ? (v.MaxUsageCount.Value - v.CurrentUsageCount) : int.MaxValue))</td>
                    <td class="px-3 py-2">@v.EndDate.ToShortDateString()</td>
                    <td class="px-3 py-2">
                        @if (v.IsActive)
                        {
                            <span class="text-green-400">@L["Active"]</span>
                        }
                        else
                        {
                            <span class="text-red-600">@L["Inactive"]</span>
                        }
                    </td>
                    <td class="px-3 py-2 space-x-2">
                        <button class="text-amber-500 hover:underline"
                                @onclick='() => Nav.NavigateTo($"/admin/vouchers/edit/{v.Id}")'>
                            @L["Edit"]
                        </button>
                        <button class="text-red-500 hover:underline"
                                @onclick="() => ConfirmAndDelete(v.Id)">
                            @L["Delete"]
                        </button>
                        <button class="text-gray-400 hover:underline"
                                @onclick="() => ToggleVoucher(v.Id)">
                            @(v.IsActive? L["Deactivate"] : L["Activate"])
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <!-- Pagination -->
    <div class="flex flex-col items-center space-y-2 mt-4 text-sm text-amber-600">
        <div class="w-full flex justify-center">
            <select class="w-full max-w-xs px-3 py-1 rounded bg-neutral-800 border border-neutral-600 text-amber-600 text-center"
                    @onchange="OnPageSizeChanged">
                <option value="8">8 @L["PerPage"]</option>
                <option value="16">16 @L["PerPage"]</option>
                <option value="24">24 @L["PerPage"]</option>
            </select>
        </div>
        <div class="w-full max-w-xs flex items-center justify-between">
            <button @onclick="PrevPage" disabled="@(!CanPrevPage)"
                    class="px-3 py-1 text-center rounded bg-neutral-800 hover:bg-neutral-700 disabled:opacity-50">
                @L["Previous"]
            </button>
            <span class="text-amber-600">@L["PageOf", currentPage, totalPages]</span>
            <button @onclick="NextPage" disabled="@(!CanNextPage)"
                    class="px-3 py-1 text-center rounded bg-neutral-800 hover:bg-neutral-700 disabled:opacity-50">
                @L["Next"]
            </button>
        </div>
    </div>
}

@code {
    private List<Voucher> allVouchers = new();
    private List<Voucher> pagedVouchers = new();

    private string _searchTerm = "";
    private string searchTerm
    {
        get => _searchTerm;
        set
        {
            if (_searchTerm != value)
            {
                _searchTerm = value;
                ApplyFilters();
            }
        }
    }

    private string selectedStatus = "";
    private int currentPage = 1;
    private int pageSize = 8;
    private int totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadVouchers();
    }

    private async Task LoadVouchers()
    {
        var token = await AdminAuth.GetTokenAsync();
        if (string.IsNullOrEmpty(token)) return;

        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        try
        {
            allVouchers = await Http.GetFromJsonAsync<List<Voucher>>("vouchers") ?? new();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine("⚠️ Failed to load vouchers: " + ex.Message);
        }
    }

    private void ApplyFilters()
    {
        var filtered = allVouchers;

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            filtered = filtered
                .Where(v => v.Code.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }

        if (!string.IsNullOrWhiteSpace(selectedStatus))
        {
            if (selectedStatus == "true")
                filtered = filtered.Where(v => v.IsActive).ToList();
            else if (selectedStatus == "false")
                filtered = filtered.Where(v => !v.IsActive).ToList();
        }

        totalPages = Math.Max(1, (int)Math.Ceiling(filtered.Count / (double)pageSize));
        if (currentPage > totalPages) currentPage = totalPages;

        pagedVouchers = filtered
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void OnStatusChanged(ChangeEventArgs e)
    {
        selectedStatus = e.Value?.ToString() ?? "";
        currentPage = 1;
        ApplyFilters();
    }

    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            pageSize = size;
            currentPage = 1;
            ApplyFilters();
        }
    }

    private void PrevPage()
    {
        if (currentPage > 1) currentPage--;
        ApplyFilters();
    }

    private void NextPage()
    {
        if (currentPage < totalPages) currentPage++;
        ApplyFilters();
    }

    private bool CanPrevPage => currentPage > 1;
    private bool CanNextPage => currentPage < totalPages;

    private async Task<bool> Confirm(string message)
    {
        return await JS.InvokeAsync<bool>("confirm", message);
    }

    private async Task ConfirmAndDelete(int voucherId)
    {
        if (await Confirm("Are you sure you want to DELETE this voucher?"))
        {
            await DeleteVoucher(voucherId);
        }
    }

    private async Task DeleteVoucher(int voucherId)
    {
        await Http.DeleteAsync($"vouchers/{voucherId}");
        await LoadVouchers();
    }

    private async Task ToggleVoucher(int voucherId)
    {
        await Http.PutAsync($"vouchers/{voucherId}/toggle", null);
        await LoadVouchers();
    }
}
