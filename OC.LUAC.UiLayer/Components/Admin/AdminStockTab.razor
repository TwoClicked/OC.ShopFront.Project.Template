@using System.Net.Http.Json
@inject HttpClient Http
@inject AdminAuthService AdminAuth
@inject NavigationManager Nav
@attribute [Authorize(Roles = "Admin")]
@inject Microsoft.Extensions.Localization.IStringLocalizer<AdminStockTab> L

<h2 class="text-2xl font-bold mb-6 text-amber-600">@L["StockTitle"]</h2>
@if (groupedProducts == null)
{
    <p class="text-gray-400">@L["LoadingStock"]</p>
}
else if (!groupedProducts.Any())
{
    <p class="text-gray-400">@L["NoLowStock"]</p>
}
else
{
    @foreach (var p in PagedProducts)
    {
        <div class="mb-4 bg-neutral-900 rounded border border-neutral-700">
            <!-- Product header -->
            <div class="flex justify-between items-center px-4 py-3 cursor-pointer hover:bg-neutral-800"
                 @onclick="() => ToggleExpand(p.ProductId)">
                <div class="font-semibold text-amber-500">@GetLocalizedProductName(p)</div>
                <span class="text-gray-400 text-sm">
                    (@p.Variants.Count @L["VariantsLow"])
                </span>
            </div>
            <!-- Expandable list -->
            @if (expandedProducts.Contains(p.ProductId))
            {
                <table class="w-full text-center border-collapse">
                    <thead class="bg-neutral-800 text-gray-400 uppercase text-xs">
                        <tr>
                            <th class="px-3 py-2">@L["Size"]</th>
                            <th class="px-3 py-2">@L["Stock"]</th>
                            <th class="px-3 py-2">@L["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in p.Variants)
                        {
                            <tr class="border-b border-neutral-700">
                                <td class="px-3 py-2">@v.Size</td>
                                <td class="px-3 py-2 text-red-400 font-bold">@v.Stock</td>
                                <td class="px-3 py-2">
                                    <button class="text-amber-500 hover:underline"
                                            @onclick="@(() => Nav.NavigateTo($"/admin/stock/log/{v.Id}"))">
                                        @L["ViewLog"]
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
    <!-- Pagination -->
    <div class="flex justify-between items-center mt-6">
        <div class="flex space-x-2">
            <button class="px-3 py-1 rounded bg-neutral-800 text-gray-300 hover:bg-neutral-700"
                    disabled="@(_page == 1)"
                    @onclick="PrevPage">
                @L["Prev"]
            </button>
            <button class="px-3 py-1 rounded bg-neutral-800 text-gray-300 hover:bg-neutral-700"
                    disabled="@(_page >= TotalPages)"
                    @onclick="NextPage">
                @L["Next"]
            </button>
        </div>
        <select class="bg-neutral-800 text-gray-300 px-2 py-1 rounded"
                @onchange="OnPageSizeChanged">
            <option value="8" selected="@(_pageSize == 8)">8 @L["PerPage"]</option>
            <option value="16" selected="@(_pageSize == 16)">16 @L["PerPage"]</option>
            <option value="24" selected="@(_pageSize == 24)">24 @L["PerPage"]</option>
        </select>
    </div>
}
@code {
    private List<ProductGroupVm>? groupedProducts;
    private HashSet<int> expandedProducts = new();
    private int _page = 1;
    private int _pageSize = 8;
    private int TotalPages => groupedProducts == null ? 1 : (int)Math.Ceiling(groupedProducts.Count / (double)_pageSize);
    private IEnumerable<ProductGroupVm> PagedProducts =>
        groupedProducts?.Skip((_page - 1) * _pageSize).Take(_pageSize) ?? Enumerable.Empty<ProductGroupVm>();
    protected override async Task OnInitializedAsync()
    {
        await LoadLowStock();
    }
    private async Task LoadLowStock()
    {
        try
        {
            var token = await AdminAuth.GetTokenAsync();
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var lowStock = await Http.GetFromJsonAsync<List<LowStockVm>>("stock/low?threshold=5") ?? new();
            groupedProducts = lowStock
                .GroupBy(v => new { v.ProductId, v.NameEn, v.NameDe })
                .Select(g => new ProductGroupVm
                {
                    ProductId = g.Key.ProductId,
                    NameEn = g.Key.NameEn,
                    NameDe = g.Key.NameDe,
                    Variants = g.Select(x => new VariantVm
                    {
                        Id = x.Id,
                        Size = x.Size,
                        Stock = x.Stock
                    }).ToList()
                })
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine("⚠️ Failed to load low stock: " + ex.Message);
            groupedProducts = new();
        }
    }
    private void ToggleExpand(int productId)
    {
        if (expandedProducts.Contains(productId))
            expandedProducts.Remove(productId);
        else
            expandedProducts.Add(productId);
    }
    private void PrevPage()
    {
        if (_page > 1) _page--;
    }
    private void NextPage()
    {
        if (_page < TotalPages) _page++;
    }
    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            _pageSize = size;
            _page = 1;
        }
    }
    private string GetLocalizedProductName(ProductGroupVm vm)
        => System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "de" && !string.IsNullOrWhiteSpace(vm.NameDe)
            ? vm.NameDe
            : vm.NameEn;

    // --- View Models ---
    private class LowStockVm
    {
        public int Id { get; set; }
        public int ProductId { get; set; }
        public string NameEn { get; set; } = "";
        public string NameDe { get; set; } = "";
        public string Size { get; set; } = "";
        public int Stock { get; set; }
    }
    private class ProductGroupVm
    {
        public int ProductId { get; set; }
        public string NameEn { get; set; } = "";
        public string NameDe { get; set; } = "";
        public List<VariantVm> Variants { get; set; } = new();
    }
    private class VariantVm
    {
        public int Id { get; set; }
        public string Size { get; set; } = "";
        public int Stock { get; set; }
    }
}
