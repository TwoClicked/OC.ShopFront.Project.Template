@inherits LayoutComponentBase

<div class="min-h-screen flex flex-col bg-neutral-900 text-white">
    <!-- Navbar -->
    <header class="bg-neutral-900 shadow-md">
        <nav class="container mx-auto flex justify-between items-center p-4">
            <a href="/" class="flex items-center">
                <img src="/images/WHITE_LUAC.png" alt="LUAC Logo" class="h-24 w-auto" />
            </a>

            <ul class="flex space-x-6">
                <li><NavLink href="/" class="hover:text-indigo-400">Home</NavLink></li>
                <li><NavLink href="/shop" class="hover:text-indigo-400">Shop</NavLink></li>
                <li><NavLink href="/cart" class="hover:text-indigo-400">Cart</NavLink></li>
                <li><NavLink href="/account" class="hover:text-indigo-400">Account</NavLink></li>
            </ul>
        </nav>
    </header>

    <!-- Main content -->
    <main class="flex-1 container mx-auto p-6">
        @Body
    </main>

    <!-- Footer -->
    <footer class="bg-neutral-900 text-center p-4 text-sm text-gray-400">
        © @DateTime.Now.Year - LUAC. All rights reserved.
    </footer>
</div>
